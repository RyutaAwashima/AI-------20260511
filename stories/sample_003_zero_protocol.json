    "assets_needed": [
      "ren.png — 近未来の若い調査員・男性（表情: normal / serious / shocked）",
      "aria.png — AI少女・ホログラム投影・青白い光（表情: normal / alert / concerned）",
      "stranger.png — フードを被った謎の男・顔不明（表情: neutral / smirk）",
      "bg_city_night.jpg — 雨の近未来都市・高層ビルとネオン",
      "bg_ruins.jpg — 廃工場の内部・薄暗・機械の残骸",
      "bgm_tense.mp3 — 緊張感のある静かな電子音楽",
